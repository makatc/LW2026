# Database
DATABASE_URL=postgresql://dev:dev@localhost:5432/sutra_monitor

# Redis
REDIS_URL=redis://localhost:6379

# Scraping
SUTRA_BASE_URL=https://sutra.oslpr.org
SCRAPER_RATE_LIMIT_MS=2000
SCRAPER_MAX_RETRIES=3
SCRAPER_TIMEOUT_MS=30000

# Jobs
INGEST_CRON=0 */6 * * *
DISCOVERY_CRON=0 */12 * * *
TRACKING_CRON=0 */4 * * *

# Logging
LOG_LEVEL=info
